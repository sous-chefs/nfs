# Generated by Chef for <%= node['fqdn'] -%>
# Local modifications will be overwritten.
#
# This is a general configuration for the
# NFS daemons and tools
[general]
pipefs-directory=<%= @pipefs_directory %>

[gssd]
use-gss-proxy=1

[lockd]
port=<%= @lockd_port %>
udp-port=<%= @lockd_port %>

[mountd]
port=<%= @mountd_port %>

[nfsd]
threads=<%= @threads %>

[statd]
port=<%= @statd_port %>
outgoing-port=<%= @statd_out_port %>
