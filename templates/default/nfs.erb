# Generated by Chef for <%= node['fqdn'] -%>
# Local modifications will be overwritten.
<% case node['platform_family'] -%>
<%# RHEL -%>
<% when 'rhel' -%>
# Rendered RHEL template variant
STATD_PORT="<%= @statd_port -%>"
STATD_OUTGOING_PORT="<%= @statd_out_port -%>"
STATDARG="-p <%= @statd_port -%> -o <%= @statd_out_port -%>"
MOUNTD_PORT="<%= @mountd_port -%>"
RPCMOUNTDOPTS="-p <%= @mountd_port -%>"
LOCKD_UDPPORT="<%= @lockd_port -%>"
LOCKD_TCPPORT="<%= @lockd_port -%>"
RQUOTAD_PORT="<%= @rquotad_port -%>"
  <% unless @nfs_v2.nil? -%>
MOUNTD_NFS_V2="<%= @nfs_v2 -%>"
  <% end -%>
  <% unless @nfs_v3.nil? -%>
MOUNTD_NFS_V3="<%= @nfs_v3 -%>"
  <% end -%>
RQUOTAD="<%= @rquotad -%>"
  <% unless @threads == 0 -%>
RPCNFSDCOUNT="<%= @threads -%>"
  <% end -%>

<%# SUSE -%>
<% when 'suse' -%>
# Rendered SUSE template variant
  <% unless @threads == 0 -%>
USE_KERNEL_NFSD_NUMBER="<%= @threads -%>"
  <% end -%>
MOUNTD_PORT="<%= @mountd_port -%>"
STATD_PORT="<%= @statd_port -%>"
LOCKD_TCPPORT="<%= @lockd_port -%>"
LOCKD_UDPPORT="<%= @lockd_port -%>"
NFS_START_SERVICES="yes"
  <% unless @nfs_v4.nil? -%>
NFS4_SUPPORT="<%= @nfs_v4 -%>"
  <% end -%>

<%# FreeBSD -%>
<% when 'freebsd' -%>
# Rendered FreeBSD template variant
portmap_enabled="YES"
nfs_server_enable="YES"
  <% unless @nfs_v4.nil? -%>
nfsv4_server_enable="<%= @nfs_v4 -%>"
  <% end -%>
nfs_server_flags="-u -t -n <%= @threads -%>"

<%# Debian/Ubuntu -%>
<% when 'debian' -%>
# Rendered Debian/Ubuntu template variant
RPCMOUNTDOPTS="-p <%= @mountd_port %>"
  <% unless @threads == 0 -%>
RPCNFSDCOUNT="<%= @threads -%><% if @nfs_v4 == 'no' -%> --no-nfs-version 4<% end -%>"
  <% end -%>
<% end -%>
